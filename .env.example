# ============================================================
# AI Gateway Proxy — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_NAME="AI Gateway Proxy"
DEBUG=false
SECRET_KEY=change-me-to-a-random-64-char-string

# ── Database ─────────────────────────────────────────────────
POSTGRES_PASSWORD=your_strong_postgres_password

# ── Microsoft OAuth2 (Azure AD) ──────────────────────────────
# Register your app at: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_TENANT_ID=your-azure-tenant-id
# Must match the redirect URI registered in Azure AD
AZURE_REDIRECT_URI=http://your-domain/api/v1/auth/oauth/callback

# ── Super Admin (First Login) ─────────────────────────────────
SUPER_ADMIN_USERNAME=openai
SUPER_ADMIN_PASSWORD=openai
SUPER_ADMIN_EMAIL=admin@ai-gateway.local
SUPER_ADMIN_DISPLAY_NAME=Super Admin

# ── Frontend URL (for OAuth callback redirect) ────────────────
FRONTEND_URL=http://your-domain

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list handled in config.py
